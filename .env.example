# Copier en .env pour un build LIVE en local (lecture de la vraie base Notion).
# En CI, ces valeurs sont des « repo secrets » GitHub (jamais committées).
# Sans NOTION_TOKEN, le build bascule automatiquement en mode démonstration.

NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATA_SOURCE_ID=21366175-3d72-401c-9ecc-b76b1ac513bf
SITE_PASSWORD=choisir-un-mot-de-passe-fort
